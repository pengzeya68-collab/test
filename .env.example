# TestMaster Backend - 环境变量配置
# 复制此文件为 .env 并修改相应配置

# ==================== 应用基础配置 ====================
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
PROJECT_NAME=TestMaster Backend
VERSION=1.0.0
ENVIRONMENT=development
HOST=0.0.0.0
PORT=5001

# ==================== 数据库配置 ====================
DATABASE_URL=sqlite+aiosqlite:///./instance/testmaster.db
AUTO_CREATE_TABLES_ON_STARTUP=false

# ==================== Redis 配置 ====================
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ==================== CORS 配置 ====================
# 多个域名用逗号分隔
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173

# ==================== JWT 配置 ====================
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_MINUTES=10080

# ==================== 管理员配置 ====================
# 开发环境留空则自动生成随机值；生产环境必须手动设置
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
ADMIN_SECRET_KEY=

# ==================== 加密配置 ====================
# 用于加密数据库中的敏感字段（如 AI API Key）
# 开发环境留空则自动生成随机值；生产环境必须手动设置固定值
TESTMASTER_ENCRYPTION_KEY=

# ==================== AI 配置 ====================
AI_PROVIDER=openai
AI_API_KEY=sk-your-openai-api-key
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4-turbo-preview

# AI 速率限制配置（防止 API Key 被刷爆）
AI_RATE_LIMIT_REQUESTS=10
AI_RATE_LIMIT_WINDOW_SECONDS=60

# ==================== AutoTest 配置 ====================
AUTO_TEST_BASE_URL=http://localhost:5001

# ==================== 邮件配置 ====================
EMAIL_SMTP_HOST=smtp.example.com
EMAIL_SMTP_PORT=465
EMAIL_SMTP_USER=your-email@example.com
EMAIL_SMTP_PASSWORD=your-email-password
EMAIL_FROM_ADDRESS=noreply@example.com
EMAIL_ENABLED=false

# ==================== Webhook 通知 ====================
WEBHOOK_URL=
