# TestMasterProject 环境变量配置
# 复制此文件为 .env 并填写实际值

# FastAPI JWT 密钥（必须设置，建议使用随机生成的长字符串）
SECRET_KEY=your-super-secret-key-here-at-least-32-characters-long


# 数据库配置（可选，默认使用 SQLite）
# DATABASE_URL=mysql+pymysql://username:password@localhost/testmaster

# OpenAI API 配置（可选，用于AI导师功能）
# OPENAI_API_KEY=your-openai-api-key
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-3.5-turbo

# 短信服务配置（可选，用于发送验证码）
# SMS_ACCESS_KEY_ID=your-access-key
# SMS_ACCESS_KEY_SECRET=your-secret
# SMS_SIGN_NAME=your-sign-name
# SMS_TEMPLATE_CODE=your-template-code

# Runtime safety toggles
# RATELIMIT_ENABLED=true
# AUTO_BACKUP_ON_STARTUP=false
# AUTO_CREATE_TABLES_ON_STARTUP=false

# Auto test platform CORS allowlist, comma separated
# AUTO_TEST_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5001,http://127.0.0.1:5001
