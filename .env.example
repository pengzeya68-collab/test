# TestMaster Backend - 环境变量配置
# 复制此文件为 .env 并修改相应配置

# ==================== 数据库密码（Docker Compose 必需） ====================
# 警告: 请使用强密码，不要使用默认值！部署脚本会自动生成随机密码。
DB_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD

# ==================== 应用基础配置 ====================
# 警告: 生产环境必须修改！部署脚本会自动生成随机密钥。
SECRET_KEY=CHANGE_ME_TO_A_RANDOM_SECRET_KEY_MIN_32_CHARS
PROJECT_NAME=TestMaster Backend
VERSION=1.0.0
ENVIRONMENT=production
HOST=0.0.0.0
PORT=5001

# ==================== 数据库配置 ====================
DATABASE_URL=postgresql+asyncpg://testmaster:CHANGE_ME_TO_A_STRONG_PASSWORD@postgres:5432/testmaster
AUTO_CREATE_TABLES_ON_STARTUP=true

# ==================== Redis 配置 ====================
# 生产环境建议设置密码保护: redis://:your_password@redis:6379/0
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ==================== CORS 配置 ====================
CORS_ORIGINS=https://your-domain.com,http://localhost:3000

# ==================== JWT 配置 ====================
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_MINUTES=10080

# ==================== 管理员配置 ====================
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
ADMIN_SECRET_KEY=

# ==================== 加密配置 ====================
TESTMASTER_ENCRYPTION_KEY=

# ==================== AI 配置 ====================
AI_PROVIDER=openai
AI_API_KEY=CHANGE_ME_TO_YOUR_AI_API_KEY
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4-turbo-preview

AI_RATE_LIMIT_REQUESTS=10
AI_RATE_LIMIT_WINDOW_SECONDS=60

# ==================== AutoTest 配置 ====================
AUTO_TEST_BASE_URL=http://backend:5001

# ==================== 邮件配置 ====================
EMAIL_SMTP_HOST=smtp.example.com
EMAIL_SMTP_PORT=465
EMAIL_SMTP_USER=your-email@example.com
EMAIL_SMTP_PASSWORD=your-email-password
EMAIL_FROM_ADDRESS=noreply@example.com
EMAIL_ENABLED=false

# ==================== Webhook 通知 ====================
WEBHOOK_URL=

# ==================== 微信小程序配置 ====================
WECHAT_MINI_APP_ID=
WECHAT_MINI_APP_SECRET=
