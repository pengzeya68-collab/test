SECRET_KEY=your-super-secret-key-here-at-least-32-characters-long
DATABASE_URL=sqlite+aiosqlite:///./instance/testmaster.db
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

AI_PROVIDER=openai
AI_API_KEY=your-openai-api-key
