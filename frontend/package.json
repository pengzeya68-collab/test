{
  "name": "testmaster-frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .gitignore",
    "test": "echo 'No tests configured yet. Add a test framework like Vitest to enable testing.'",
    "test:e2e": "playwright test -c ../playwright.config.js",
    "test:e2e:headed": "playwright test -c ../playwright.config.js --headed",
    "test:e2e:report": "playwright show-report ../playwright-report"
  },
  "dependencies": {
    "@codemirror/commands": "^6.3.2",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-python": "^6.1.3",
    "@codemirror/lang-sql": "^6.5.4",
    "@codemirror/language": "^6.9.3",
    "@codemirror/state": "^6.3.3",
    "@codemirror/view": "^6.22.3",
    "@element-plus/icons-vue": "^2.3.1",
    "@vueuse/core": "^10.7.0",
    "axios": "^1.6.2",
    "dompurify": "^3.4.7",
    "echarts": "^5.4.3",
    "element-plus": "^2.4.4",
    "marked": "^11.1.1",
    "papaparse": "^5.4.1",
    "pinia": "^2.1.7",
    "vue": "^3.3.11",
    "vue-echarts": "^6.6.8",
    "vue-router": "^4.2.5",
    "vue3-count-to": "^1.1.2",
    "vuedraggable": "^4.1.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@rushstack/eslint-patch": "^1.16.1",
    "@vitejs/plugin-vue": "^4.5.2",
    "eslint": "^8.56.0",
    "eslint-plugin-vue": "^9.19.2",
    "sass-embedded": "^1.69.5",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.1.0",
    "vite": "^5.0.8",
    "vite-plugin-remove-console": "^2.2.0"
  }
}
