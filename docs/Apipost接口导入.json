            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "query": [
              {
                "key": "page",
                "value": "1"
              },
              {
                "key": "size",
                "value": "10"
              },
              {
                "key": "keyword",
                "value": ""
              },
              {
                "key": "difficulty",
                "value": ""
              },
              {
                "key": "category",
                "value": ""
              },
              {
                "key": "stage",
                "value": ""
              }
            ]
          }
        },
        {
          "name": "新增习题",
          "method": "POST",
          "url": "{{baseUrl}}/admin/exercises",
          "request": {
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Python基础题\",\n  \"description\": \"请编写一个Python程序输出Hello World\",\n  \"difficulty\": \"easy\",\n  \"category\": \"Python\",\n  \"stage\": \"基础阶段\",\n  \"points\": 10,\n  \"time_limit\": 30,\n  \"code_template\": \"# 请在这里编写代码\",\n  \"test_cases\": \"[]\",\n  \"solution\": \"print('Hello World')\",\n  \"is_published\": true\n}"
            }
