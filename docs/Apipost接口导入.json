    {
      "name": "前台接口",
      "items": [
        {
          "name": "前台获取习题列表",
          "method": "GET",
          "url": "{{baseUrl}}/exercises",
          "request": {
            "query": [
              {
                "key": "page",
                "value": "1"
              },
              {
                "key": "size",
                "value": "10"
              },
              {
                "key": "keyword",
                "value": ""
              }
            ]
          }
        },
        {
          "name": "前台获取习题详情",
          "method": "GET",
          "url": "{{baseUrl}}/exercises/:exercise_id",
          "request": {
            "params": [
              {
                "key": "exercise_id",
                "value": "1"
              }
            ]
          }
        },
        {
          "name": "前台获取学习路径列表",
          "method": "GET",
          "url": "{{baseUrl}}/learning-paths"
        },
        {
          "name": "前台获取学习路径详情",
          "method": "GET",
          "url": "{{baseUrl}}/learning-paths/:path_id",
          "request": {
            "params": [
              {
                "key": "path_id",
                "value": "1"
              }
            ]
          }
        }
      ]
    }
  ],
  "variables": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000/api",
      "description": "后端接口地址"
    },
    {
      "key": "user_token",
      "value": "",
      "description": "普通用户登录后的token"
    },
    {
      "key": "admin_token",
      "value": "",
      "description": "管理员登录后的token"
    },
    {
      "key": "refresh_token",
      "value": "",
      "description": "刷新token"
    }
  ]
}
