              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Python入门学习路径\",\n  \"description\": \"从零基础到掌握Python基础语法\",\n  \"icon\": \"🐍\",\n  \"level\": 1,\n  \"estimated_time\": 120,\n  \"exercise_ids\": [1, 2, 3],\n  \"is_published\": true\n}"
