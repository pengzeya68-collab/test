page {
  background-color: #F8F9FA;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  color: #2D3436;
  font-size: 28rpx;
  line-height: 1.6;
}

view, text, scroll-view {
  box-sizing: border-box;
}

.container {
  padding: 24rpx;
  padding-bottom: 120rpx;
}

.card {
  background: #FFFFFF;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.btn-primary {
  background: linear-gradient(135deg, #6C5CE7, #A29BFE);
  color: #FFFFFF;
  border: none;
  border-radius: 24rpx;
  padding: 20rpx 40rpx;
  font-size: 28rpx;
  font-weight: 500;
  text-align: center;
}

.btn-primary::after {
  border: none;
}

.btn-outline {
  background: #FFFFFF;
  color: #6C5CE7;
  border: 2rpx solid #6C5CE7;
  border-radius: 24rpx;
  padding: 18rpx 38rpx;
  font-size: 28rpx;
  font-weight: 500;
  text-align: center;
}

.btn-outline::after {
  border: none;
}

.btn-danger {
  background: #FF6B6B;
  color: #FFFFFF;
  border: none;
  border-radius: 24rpx;
  padding: 20rpx 40rpx;
  font-size: 28rpx;
  font-weight: 500;
  text-align: center;
}

.btn-danger::after {
  border: none;
}

.btn-sm {
  padding: 12rpx 24rpx;
  font-size: 24rpx;
}

.tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 32rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.tag-easy {
  background: rgba(0, 184, 148, 0.1);
  color: #00B894;
}

.tag-medium {
  background: rgba(253, 203, 110, 0.2);
  color: #FDCB6E;
}

.tag-hard {
  background: rgba(255, 107, 107, 0.1);
  color: #FF6B6B;
}

.tag-success {
  background: rgba(0, 184, 148, 0.1);
  color: #00B894;
}

.tag-fail {
  background: rgba(255, 107, 107, 0.1);
  color: #FF6B6B;
}

.tag-pending {
  background: rgba(178, 190, 195, 0.15);
  color: #B2BEC3;
}

.tag-running {
  background: rgba(116, 185, 255, 0.15);
  color: #74B9FF;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #2D3436;
}

.text-primary {
  color: #6C5CE7;
}

.text-success {
  color: #00B894;
}

.text-danger {
  color: #FF6B6B;
}

.text-warning {
  color: #FDCB6E;
}

.text-info {
  color: #74B9FF;
}

.text-muted {
  color: #636E72;
}

.text-sm {
  font-size: 24rpx;
}

.text-lg {
  font-size: 36rpx;
}

.text-xl {
  font-size: 44rpx;
}

.text-center {
  text-align: center;
}

.text-right {
  text-align: right;
}

.flex-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.flex-col {
  display: flex;
  flex-direction: column;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.flex-wrap {
  display: flex;
  flex-wrap: wrap;
}

.mt-10 {
  margin-top: 10rpx;
}

.mt-20 {
  margin-top: 20rpx;
}

.mt-30 {
  margin-top: 30rpx;
}

.mb-10 {
  margin-bottom: 10rpx;
}

.mb-20 {
  margin-bottom: 20rpx;
}

.mb-30 {
  margin-bottom: 30rpx;
}

.ml-10 {
  margin-left: 10rpx;
}

.mr-10 {
  margin-right: 10rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
}

.empty-icon {
  font-size: 80rpx;
  color: #B2BEC3;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #B2BEC3;
}

.loading-box {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.search-box {
  display: flex;
  align-items: center;
  background: #F0F0F5;
  border-radius: 24rpx;
  padding: 16rpx 24rpx;
}

.input-field {
  width: 100%;
  padding: 16rpx 24rpx;
  background: #F8F9FA;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #2D3436;
  border: 2rpx solid transparent;
}

.divider {
  height: 1rpx;
  background: #F0F0F5;
  margin: 20rpx 0;
}

.badge {
  display: inline-block;
  width: 16rpx;
  height: 16rpx;
  background: #FF6B6B;
  border-radius: 50%;
  position: absolute;
  top: 0;
  right: 0;
}

.progress-bar {
  width: 100%;
  height: 12rpx;
  background: #F0F0F5;
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-bar-fill {
  height: 100%;
  background: linear-gradient(135deg, #6C5CE7, #A29BFE);
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  overflow: hidden;
  background: #F0F0F5;
}

.stat-card {
  background: #FFFFFF;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
  padding: 24rpx;
  text-align: center;
}

.stat-value {
  font-size: 44rpx;
  font-weight: 700;
  color: #2D3436;
}

.stat-label {
  font-size: 24rpx;
  color: #636E72;
  margin-top: 8rpx;
}
