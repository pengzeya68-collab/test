.pwd-page { background: #F8F9FA; min-height: 100vh; padding: 30rpx; }
.pwd-form { padding: 40rpx 30rpx; }
.form-section { margin-bottom: 30rpx; }
.form-label { font-size: 28rpx; font-weight: 600; color: #2D3436; margin-bottom: 12rpx; display: block; }
.form-input { background: #F8F9FA; border-radius: 16rpx; padding: 24rpx; font-size: 30rpx; height: 88rpx; box-sizing: border-box; }
.submit-btn { width: 100%; margin-top: 20rpx; }
