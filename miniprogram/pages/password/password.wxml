<view class="pwd-page">
  <view class="pwd-form card">
    <view class="form-section">
      <text class="form-label">当前密码</text>
      <input class="form-input" placeholder="请输入当前密码" password="{{true}}" value="{{oldPassword}}" bindinput="onOldPwdInput" />
    </view>
    <view class="form-section">
      <text class="form-label">新密码</text>
      <input class="form-input" placeholder="请输入新密码(至少6位)" password="{{true}}" value="{{newPassword}}" bindinput="onNewPwdInput" />
    </view>
    <view class="form-section">
      <text class="form-label">确认新密码</text>
      <input class="form-input" placeholder="请再次输入新密码" password="{{true}}" value="{{confirmPassword}}" bindinput="onConfirmInput" />
    </view>
    <button class="btn-primary submit-btn" bindtap="changePassword" loading="{{loading}}" disabled="{{loading}}">
      修改密码
    </button>
  </view>
</view>
