<view class="container">
  <view class="profile-header">
    <image class="profile-avatar" src="{{userInfo.avatar || '/images/default-avatar.png'}}" mode="aspectFill"></image>
    <view class="profile-info">
      <text class="profile-name">{{userInfo.username || '未登录'}}</text>
      <text class="profile-email">{{userInfo.email || ''}}</text>
    </view>
  </view>

  <view class="stats-row">
    <view class="stat-item">
      <text class="stat-value">{{stats.exercises || 0}}</text>
      <text class="stat-label">已完成习题</text>
    </view>
    <view class="stat-item">
      <text class="stat-value">{{stats.streak || 0}}</text>
      <text class="stat-label">学习天数</text>
    </view>
    <view class="stat-item">
      <text class="stat-value">{{stats.score || 0}}</text>
      <text class="stat-label">积分</text>
    </view>
  </view>

  <view class="menu-card">
    <view class="menu-item" bindtap="goPage" data-url="/pages/favorites/favorites">
      <text class="menu-icon">⭐</text>
      <text class="menu-text">我的收藏</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goPage" data-url="/pages/learning/paths">
      <text class="menu-icon">📊</text>
      <text class="menu-text">学习报告</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goPage" data-url="/pages/learning/paths">
      <text class="menu-icon">🎯</text>
      <text class="menu-text">技能雷达</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goPage" data-url="/pages/notifications/notifications">
      <text class="menu-icon">�</text>
      <text class="menu-text">通知中心</text>
      <view class="menu-badge" wx:if="{{unreadCount > 0}}">{{unreadCount}}</view>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goSetup">
      <text class="menu-icon">⚙️</text>
      <text class="menu-text">服务器设置</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="handleLogout">
      <text class="menu-icon">🚪</text>
      <text class="menu-text logout-text">退出登录</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>
</view>
