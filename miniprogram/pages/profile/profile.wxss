page {
  background: #F5F3FF;
}

.container {
  padding: 24rpx;
}

.profile-header {
  padding: 48rpx 32rpx;
  background: linear-gradient(135deg, #6C5CE7, #A29BFE);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
  color: #fff;
}

.profile-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.5);
  margin-right: 28rpx;
  background: rgba(255, 255, 255, 0.2);
}

.profile-info {
  display: flex;
  flex-direction: column;
}

.profile-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 6rpx;
}

.profile-email {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.stats-row {
  display: flex;
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx 0;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(108, 92, 231, 0.08);
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #6C5CE7;
}

.stat-label {
  font-size: 22rpx;
  color: #636E72;
  margin-top: 6rpx;
}

.menu-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 0 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(108, 92, 231, 0.08);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 0;
  border-bottom: 1rpx solid #F0F0F5;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
  color: #2D3436;
  font-weight: 500;
}

.logout-text {
  color: #E17055;
}

.menu-badge {
  background: #E17055;
  color: #fff;
  font-size: 22rpx;
  padding: 2rpx 14rpx;
  border-radius: 20rpx;
  min-width: 32rpx;
  text-align: center;
  margin-right: 12rpx;
}

.menu-arrow {
  font-size: 32rpx;
  color: #DFE6E9;
  margin-left: 12rpx;
}
