.profile-page {
  background: #F8F9FA;
  min-height: 100vh;
  padding-bottom: 120rpx;
}

.profile-header {
  background: linear-gradient(135deg, #6C5CE7, #A29BFE);
  padding: 50rpx 30rpx 60rpx;
  position: relative;
  overflow: hidden;
}

.profile-bg {
  position: absolute;
  top: -80rpx;
  right: -80rpx;
  width: 350rpx;
  height: 350rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.06);
}

.profile-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  z-index: 1;
}

.avatar-large {
  width: 130rpx;
  height: 130rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.25);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid rgba(255, 255, 255, 0.5);
  margin-bottom: 16rpx;
}

.avatar-letter {
  font-size: 52rpx;
  font-weight: 800;
  color: #FFFFFF;
}

.profile-name {
  font-size: 38rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 6rpx;
}

.profile-email {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.75);
  margin-bottom: 16rpx;
}

.profile-badges {
  display: flex;
  gap: 12rpx;
}

.badge {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.2);
  color: #FFFFFF;
}

.badge-active {
  background: rgba(0, 184, 148, 0.4);
}

.stats-card {
  display: flex;
  margin: -30rpx 30rpx 20rpx;
  position: relative;
  z-index: 1;
  padding: 30rpx 10rpx;
  min-height: 100rpx;
}

.stats-loading {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.loading-text {
  font-size: 26rpx;
  color: #999;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 40rpx;
  font-weight: 800;
  color: #6C5CE7;
}

.stat-name {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

.error-tip {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 0 30rpx 20rpx;
  padding: 20rpx 30rpx;
  background: #FFF5F5;
}

.error-tip-text {
  font-size: 26rpx;
  color: #E17055;
}

.error-tip-retry {
  font-size: 26rpx;
  color: #6C5CE7;
  font-weight: 600;
}

.menu-section {
  margin: 20rpx 30rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
  width: 48rpx;
  text-align: center;
}

.menu-label {
  flex: 1;
  font-size: 30rpx;
  color: #2D3436;
}

.menu-arrow {
  font-size: 32rpx;
  color: #CCC;
}

.checkin-status {
  font-size: 24rpx;
  color: #B2BEC3;
}

.checked-in {
  color: #00B894;
  font-weight: 600;
}

.logout-item {
  justify-content: center;
}

.logout-text {
  color: #E17055;
  font-weight: 600;
  text-align: center;
  flex: none;
}
