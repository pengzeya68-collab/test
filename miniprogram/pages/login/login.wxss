.login-page {
  min-height: 100vh;
  background: linear-gradient(135deg, #6C5CE7 0%, #A29BFE 50%, #74B9FF 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 40rpx;
  position: relative;
  overflow: hidden;
}

.login-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 0;
}

.bg-circle {
  position: absolute;
  border-radius: 50%;
  opacity: 0.1;
  background: #FFFFFF;
}

.circle-1 {
  width: 400rpx;
  height: 400rpx;
  top: -100rpx;
  right: -100rpx;
}

.circle-2 {
  width: 300rpx;
  height: 300rpx;
  bottom: 100rpx;
  left: -80rpx;
}

.circle-3 {
  width: 200rpx;
  height: 200rpx;
  top: 40%;
  right: 40rpx;
}

.login-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60rpx;
  z-index: 1;
}

.logo-wrap {
  width: 120rpx;
  height: 120rpx;
  background: rgba(255, 255, 255, 0.25);
  border-radius: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  backdrop-filter: blur(10px);
}

.logo-icon {
  font-size: 64rpx;
  font-weight: 800;
  color: #FFFFFF;
}

.app-name {
  font-size: 48rpx;
  font-weight: 800;
  color: #FFFFFF;
  letter-spacing: 4rpx;
}

.app-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 8rpx;
}

.login-form {
  width: 100%;
  z-index: 1;
  border-radius: 28rpx;
  padding: 40rpx;
  background: rgba(255, 255, 255, 0.95);
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.15);
}

.tab-bar {
  display: flex;
  position: relative;
  margin-bottom: 40rpx;
  background: #F0EEFF;
  border-radius: 16rpx;
  padding: 6rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  font-size: 30rpx;
  font-weight: 600;
  color: #999;
  position: relative;
  z-index: 1;
  transition: color 0.3s;
}

.tab-active {
  color: #6C5CE7;
}

.tab-indicator {
  position: absolute;
  top: 6rpx;
  left: 6rpx;
  width: calc(50% - 6rpx);
  height: calc(100% - 12rpx);
  background: #FFFFFF;
  border-radius: 12rpx;
  box-shadow: 0 4rpx 12rpx rgba(108, 92, 231, 0.15);
  transition: transform 0.3s ease;
}

.indicator-right {
  transform: translateX(100%);
}

.form-content {
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.input-group {
  display: flex;
  align-items: center;
  background: #F8F9FA;
  border-radius: 16rpx;
  padding: 0 24rpx;
  margin-bottom: 24rpx;
  border: 2rpx solid transparent;
  transition: border-color 0.3s;
}

.input-group:focus-within {
  border-color: #6C5CE7;
  background: #FFFFFF;
}

.input-icon {
  width: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.icon-text {
  font-size: 32rpx;
}

.input-field {
  flex: 1;
  height: 88rpx;
  font-size: 30rpx;
  color: #2D3436;
  padding-left: 16rpx;
}

.eye-btn {
  padding: 10rpx;
  font-size: 32rpx;
}

.login-btn {
  margin-top: 16rpx;
  width: 100%;
  height: 96rpx;
  border-radius: 16rpx;
  font-size: 34rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
}

.login-footer {
  margin-top: 60rpx;
  z-index: 1;
}

.footer-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}
