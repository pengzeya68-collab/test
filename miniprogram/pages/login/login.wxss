.login-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #6C5CE7 0%, #A29BFE 100%);
  padding: 0 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-sizing: border-box;
}

.login-header {
  padding-top: 140rpx;
  padding-bottom: 64rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.brand-icon {
  font-size: 96rpx;
  margin-bottom: 16rpx;
}

.brand-name {
  font-size: 56rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 4rpx;
  margin-bottom: 12rpx;
}

.brand-subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.85);
  letter-spacing: 2rpx;
}

.login-card {
  width: 100%;
  border-radius: 32rpx;
  padding: 48rpx;
  margin-top: 16rpx;
}

.tab-bar {
  display: flex;
  margin-bottom: 48rpx;
  border-bottom: 2rpx solid #F0F0F0;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding-bottom: 24rpx;
  font-size: 32rpx;
  color: #999;
  font-weight: 500;
  position: relative;
}

.tab-item.active {
  color: #6C5CE7;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: -2rpx;
  left: 30%;
  right: 30%;
  height: 4rpx;
  background: #6C5CE7;
  border-radius: 2rpx;
}

.input-group {
  position: relative;
  margin-bottom: 28rpx;
}

.input-icon {
  position: absolute;
  left: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 36rpx;
  z-index: 1;
}

.input-field {
  width: 100%;
  height: 88rpx;
  background: #F8F9FA;
  border-radius: 16rpx;
  padding-left: 80rpx;
  padding-right: 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  color: #333;
}

.login-btn {
  width: 100%;
  margin-top: 20rpx;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #6C5CE7, #A29BFE);
  color: #fff;
  border: none;
  letter-spacing: 4rpx;
}

.login-btn::after {
  border: none;
}

.divider {
  display: flex;
  align-items: center;
  margin: 36rpx 0;
}

.divider-line {
  flex: 1;
  height: 1rpx;
  background: #E5E7EB;
}

.divider-text {
  padding: 0 24rpx;
  font-size: 24rpx;
  color: #999;
}

.wechat-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  font-weight: 600;
  background: #07C160;
  color: #fff;
  border: none;
  border-radius: 16rpx;
  letter-spacing: 2rpx;
}

.wechat-btn::after {
  border: none;
}

.setup-title {
  font-size: 36rpx;
  font-weight: 700;
  text-align: center;
  margin-bottom: 12rpx;
  color: #333;
}

.setup-desc {
  font-size: 26rpx;
  color: #999;
  text-align: center;
  margin-bottom: 36rpx;
}

.server-entry {
  margin-top: 48rpx;
  padding-bottom: 60rpx;
}
