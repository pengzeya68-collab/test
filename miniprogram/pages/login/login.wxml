<view class="login-page">
  <view class="login-header">
    <text class="brand-icon">🎯</text>
    <text class="brand-name">TestMaster</text>
    <text class="brand-subtitle">随时随地，高效学习</text>
  </view>

  <view class="login-card card" wx:if="{{mode !== 'setup'}}">
    <view class="tab-bar">
      <view class="tab-item {{tab === 'login' ? 'active' : ''}}" bindtap="switchTab" data-tab="login">登录</view>
      <view class="tab-item {{tab === 'register' ? 'active' : ''}}" bindtap="switchTab" data-tab="register">注册</view>
    </view>

    <view wx:if="{{tab === 'login'}}">
      <view class="input-group">
        <text class="input-icon">👤</text>
        <input class="input-field" placeholder="请输入用户名" value="{{username}}" bindinput="onInput" data-field="username" />
      </view>
      <view class="input-group">
        <text class="input-icon">🔒</text>
        <input class="input-field" placeholder="请输入密码" password value="{{password}}" bindinput="onInput" data-field="password" />
      </view>
      <button class="login-btn btn-primary" bindtap="handleLogin" loading="{{loading}}">登 录</button>

      <view class="divider">
        <view class="divider-line"></view>
        <text class="divider-text">或</text>
        <view class="divider-line"></view>
      </view>

      <button class="wechat-btn" bindtap="handleWechatLogin" loading="{{wechatLoading}}">
        � 微信一键登录
      </button>
    </view>

    <view wx:if="{{tab === 'register'}}">
      <view class="input-group">
        <text class="input-icon">👤</text>
        <input class="input-field" placeholder="请输入用户名" value="{{regUsername}}" bindinput="onInput" data-field="regUsername" />
      </view>
      <view class="input-group">
        <text class="input-icon">📧</text>
        <input class="input-field" placeholder="请输入邮箱" value="{{regEmail}}" bindinput="onInput" data-field="regEmail" />
      </view>
      <view class="input-group">
        <text class="input-icon">🔒</text>
        <input class="input-field" placeholder="请输入密码" password value="{{regPassword}}" bindinput="onInput" data-field="regPassword" />
      </view>
      <view class="input-group">
        <text class="input-icon">🔐</text>
        <input class="input-field" placeholder="请再次输入密码" password value="{{regConfirmPassword}}" bindinput="onInput" data-field="regConfirmPassword" />
      </view>
      <button class="login-btn btn-primary" bindtap="handleRegister" loading="{{loading}}">注 册</button>
    </view>
  </view>

  <view class="login-card card" wx:if="{{mode === 'setup'}}">
    <view class="setup-title">⚙️ 服务器配置</view>
    <view class="setup-desc">首次使用请配置服务器地址</view>
    <view class="input-group">
      <text class="input-icon">🌐</text>
      <input class="input-field" placeholder="例如: https://your-domain.com" value="{{serverUrl}}" bindinput="onInput" data-field="serverUrl" />
    </view>
    <button class="login-btn btn-primary" bindtap="handleSaveServer">保存并继续</button>
  </view>

  <view class="server-entry" wx:if="{{mode !== 'setup'}}">
    <text class="text-muted text-sm" bindtap="goSetup">服务器设置</text>
  </view>
</view>
