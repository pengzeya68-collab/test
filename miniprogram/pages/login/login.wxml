<view class="login-page">
  <view class="login-bg">
    <view class="bg-circle circle-1"></view>
    <view class="bg-circle circle-2"></view>
    <view class="bg-circle circle-3"></view>
  </view>

  <view class="login-header">
    <view class="logo-wrap">
      <view class="logo-icon">T</view>
    </view>
    <text class="app-name">TestMaster</text>
    <text class="app-desc">测试学习 · 随时随地</text>
  </view>

  <view class="login-form card">
    <view class="tab-bar">
      <view class="tab-item {{activeTab === 'login' ? 'tab-active' : ''}}" bindtap="switchTab" data-tab="login">
        <text>登录</text>
      </view>
      <view class="tab-item {{activeTab === 'register' ? 'tab-active' : ''}}" bindtap="switchTab" data-tab="register">
        <text>注册</text>
      </view>
      <view class="tab-indicator {{activeTab === 'register' ? 'indicator-right' : ''}}"></view>
    </view>

    <view wx:if="{{activeTab === 'login'}}" class="form-content">
      <view class="input-group">
        <view class="input-icon">
          <text class="icon-text">👤</text>
        </view>
        <input class="input-field" placeholder="用户名或邮箱" value="{{username}}" bindinput="onUsernameInput" />
      </view>
      <view class="input-group">
        <view class="input-icon">
          <text class="icon-text">🔒</text>
        </view>
        <input class="input-field" placeholder="密码" password="{{!showPassword}}" value="{{password}}" bindinput="onPasswordInput" />
        <view class="eye-btn" bindtap="togglePassword">
          <text>{{showPassword ? '🙈' : '👁'}}</text>
        </view>
      </view>
      <button class="btn-primary login-btn" bindtap="handleLogin" loading="{{loading}}" disabled="{{loading}}">
        登 录
      </button>
    </view>

    <view wx:if="{{activeTab === 'register'}}" class="form-content">
      <view class="input-group">
        <view class="input-icon">
          <text class="icon-text">👤</text>
        </view>
        <input class="input-field" placeholder="用户名" value="{{regUsername}}" bindinput="onRegUsernameInput" />
      </view>
      <view class="input-group">
        <view class="input-icon">
          <text class="icon-text">📧</text>
        </view>
        <input class="input-field" placeholder="邮箱" type="text" value="{{regEmail}}" bindinput="onRegEmailInput" />
      </view>
      <view class="input-group">
        <view class="input-icon">
          <text class="icon-text">🔒</text>
        </view>
        <input class="input-field" placeholder="密码(需含字母和数字)" password="{{true}}" value="{{regPassword}}" bindinput="onRegPasswordInput" />
      </view>
      <view class="input-group">
        <view class="input-icon">
          <text class="icon-text">🔒</text>
        </view>
        <input class="input-field" placeholder="确认密码" password="{{true}}" value="{{regConfirm}}" bindinput="onRegConfirmInput" />
      </view>
      <button class="btn-primary login-btn" bindtap="handleRegister" loading="{{loading}}" disabled="{{loading}}">
        注 册
      </button>
    </view>
  </view>

  <view class="login-footer">
    <text class="footer-text">TestMaster v1.0</text>
  </view>
</view>
