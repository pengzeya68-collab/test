<view class="container">
  <view class="card">
    <view class="card-title"><text>📚 学习路径</text></view>
  </view>

  <view wx:if="{{loading && paths.length === 0}}" class="loading-wrapper">
    <text class="text-muted">加载中...</text>
  </view>

  <view wx:if="{{!loading && paths.length === 0}}" class="empty-state">
    <text class="empty-icon">📚</text>
    <text class="empty-text">暂无学习路径</text>
  </view>

  <view class="path-list">
    <view class="path-card card" wx:for="{{paths}}" wx:key="id" bindtap="goDetail" data-id="{{item.id}}">
      <text class="path-title">{{item.title || item.name}}</text>
      <text class="path-desc text-muted text-sm" wx:if="{{item.description}}">{{item.description}}</text>
      <view class="path-progress" wx:if="{{item.progress !== undefined}}">
        <view class="progress-bar">
          <view class="progress-fill" style="width: {{item.progress}}%"></view>
        </view>
        <text class="progress-text text-sm text-muted">{{item.progress}}%</text>
      </view>
      <view class="path-meta">
        <text class="text-sm text-muted">{{item.lesson_count || 0}} 课时</text>
        <text class="text-sm text-muted">{{item.exercise_count || 0}} 习题</text>
      </view>
    </view>
  </view>
</view>
