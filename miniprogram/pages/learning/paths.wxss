.path-card { margin-bottom: 16rpx; }
.path-title { font-size: 32rpx; font-weight: 600; color: #1a1a1a; display: block; margin-bottom: 8rpx; }
.path-desc { display: block; line-height: 1.5; margin-bottom: 12rpx; }
.path-progress { display: flex; align-items: center; gap: 16rpx; margin-bottom: 12rpx; }
.path-progress .progress-bar { flex: 1; height: 10rpx; background: #E5E7EB; border-radius: 5rpx; overflow: hidden; }
.path-progress .progress-fill { height: 100%; background: linear-gradient(90deg, #4F46E5, #7C3AED); border-radius: 5rpx; }
.path-meta { display: flex; gap: 24rpx; padding-top: 12rpx; border-top: 1rpx solid #F5F5F5; }
