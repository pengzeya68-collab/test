<view class="container">
  <view class="card">
    <text class="path-title-lg">{{path.title || path.name}}</text>
    <text class="text-muted text-sm" wx:if="{{path.description}}">{{path.description}}</text>
    <view class="path-progress" wx:if="{{path.progress !== undefined}}">
      <view class="progress-bar">
        <view class="progress-fill" style="width: {{path.progress}}%"></view>
      </view>
      <text class="text-sm text-muted">{{path.progress}}%</text>
    </view>
  </view>

  <view class="card">
    <view class="card-title"><text>📖 课时列表</text></view>
    <view wx:if="{{lessons.length === 0}}" class="empty-state">
      <text class="empty-text">暂无课时</text>
    </view>
    <view class="lesson-list">
      <view class="lesson-item" wx:for="{{lessons}}" wx:key="id">
        <view class="lesson-order {{item.completed ? 'completed' : ''}}">{{index + 1}}</view>
        <view class="lesson-info">
          <text class="lesson-title">{{item.title || item.name}}</text>
          <text class="text-muted text-sm" wx:if="{{item.duration}}">{{item.duration}}</text>
        </view>
        <view class="tag {{item.completed ? 'tag-pass' : 'tag-pending'}}">
          {{item.completed ? '已完成' : '未完成'}}
        </view>
      </view>
    </view>
  </view>
</view>
