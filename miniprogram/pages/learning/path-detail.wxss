.detail-page { background: #F8F9FA; min-height: 100vh; padding: 20rpx 30rpx; }
.path-header { margin-bottom: 20rpx; }
.path-title { font-size: 36rpx; font-weight: 700; color: #2D3436; display: block; margin-bottom: 10rpx; }
.path-desc { font-size: 26rpx; color: #636E72; display: block; margin-bottom: 16rpx; line-height: 1.6; }
.path-progress { display: flex; align-items: center; gap: 16rpx; }
.progress-bar { flex: 1; height: 16rpx; background: #F0F0F0; border-radius: 8rpx; overflow: hidden; }
.progress-fill { height: 100%; background: linear-gradient(90deg, #6C5CE7, #A29BFE); border-radius: 8rpx; }
.progress-text { font-size: 28rpx; font-weight: 700; color: #6C5CE7; }
.section-title { font-size: 32rpx; font-weight: 700; color: #2D3436; margin-bottom: 16rpx; }
.exercise-item { margin-bottom: 16rpx; }
.item-top { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 8rpx; }
.item-title { flex: 1; font-size: 28rpx; font-weight: 600; color: #2D3436; margin-right: 12rpx; }
.item-desc { font-size: 24rpx; color: #999; }
.empty-state { display: flex; flex-direction: column; align-items: center; padding: 80rpx 40rpx; }
.empty-icon { font-size: 60rpx; margin-bottom: 16rpx; }
.empty-text { font-size: 28rpx; color: #999; }
