.path-title-lg { font-size: 36rpx; font-weight: 700; color: #1a1a1a; display: block; margin-bottom: 8rpx; }
.path-progress { display: flex; align-items: center; gap: 16rpx; margin-top: 16rpx; }
.path-progress .progress-bar { flex: 1; height: 10rpx; background: #E5E7EB; border-radius: 5rpx; overflow: hidden; }
.path-progress .progress-fill { height: 100%; background: linear-gradient(90deg, #4F46E5, #7C3AED); border-radius: 5rpx; }
.lesson-list { margin-top: 8rpx; }
.lesson-item { display: flex; align-items: center; padding: 20rpx 0; border-bottom: 1rpx solid #F5F5F5; }
.lesson-item:last-child { border-bottom: none; }
.lesson-order { width: 48rpx; height: 48rpx; border-radius: 50%; background: #F3F4F6; color: #6B7280; display: flex; align-items: center; justify-content: center; font-size: 24rpx; font-weight: 600; margin-right: 16rpx; flex-shrink: 0; }
.lesson-order.completed { background: #ECFDF5; color: #059669; }
.lesson-info { flex: 1; display: flex; flex-direction: column; }
.lesson-title { font-size: 28rpx; font-weight: 500; color: #333; }
