.exam-header-bar { display: flex; align-items: center; justify-content: space-between; margin-bottom: 20rpx; }
.exam-title { font-size: 32rpx; font-weight: 600; color: #1a1a1a; flex: 1; }
.timer { font-size: 30rpx; font-weight: 600; color: #4F46E5; padding: 8rpx 20rpx; background: #EEF2FF; border-radius: 8rpx; }
.timer-warning { color: #DC2626; background: #FEF2F2; }
.progress-bar-wrap { margin-bottom: 24rpx; }
.progress-text { font-size: 24rpx; color: #999; margin-bottom: 8rpx; }
.progress-bar { height: 8rpx; background: #E5E7EB; border-radius: 4rpx; overflow: hidden; }
.progress-fill { height: 100%; background: linear-gradient(90deg, #4F46E5, #7C3AED); border-radius: 4rpx; transition: width 0.3s; }
.question-text { font-size: 32rpx; font-weight: 500; color: #1a1a1a; line-height: 1.6; margin-bottom: 24rpx; }
.options-list { margin-top: 8rpx; }
.option-item { display: flex; align-items: center; padding: 24rpx; margin-bottom: 16rpx; background: #F7F8FA; border-radius: 12rpx; border: 2rpx solid transparent; }
.option-item.selected { background: #EEF2FF; border-color: #4F46E5; }
.option-label { width: 48rpx; height: 48rpx; border-radius: 50%; background: #E5E7EB; display: flex; align-items: center; justify-content: center; font-size: 26rpx; font-weight: 600; color: #666; margin-right: 20rpx; flex-shrink: 0; }
.option-item.selected .option-label { background: #4F46E5; color: #fff; }
.option-text { flex: 1; font-size: 28rpx; color: #333; }
.nav-buttons { display: flex; gap: 16rpx; margin-top: 30rpx; padding-bottom: 40rpx; }
.nav-buttons button { flex: 1; margin: 0; }
