.take-page { background: #F8F9FA; min-height: 100vh; padding: 20rpx 30rpx; }
.take-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx; }
.take-title { font-size: 32rpx; font-weight: 700; color: #2D3436; flex: 1; }
.take-timer { font-size: 28rpx; font-weight: 700; color: #E17055; }
.progress-bar { height: 8rpx; background: #F0F0F0; border-radius: 4rpx; margin-bottom: 20rpx; overflow: hidden; }
.progress-fill { height: 100%; background: linear-gradient(90deg, #6C5CE7, #A29BFE); border-radius: 4rpx; transition: width 0.3s; }
.question-card { margin-bottom: 20rpx; }
.q-header { margin-bottom: 16rpx; }
.q-num { font-size: 24rpx; color: #6C5CE7; font-weight: 600; }
.q-title { font-size: 30rpx; font-weight: 600; color: #2D3436; line-height: 1.7; margin-bottom: 24rpx; white-space: pre-wrap; }
.q-options { display: flex; flex-direction: column; gap: 14rpx; }
.q-option { display: flex; align-items: center; padding: 22rpx; background: #F8F9FA; border-radius: 14rpx; border: 3rpx solid transparent; }
.q-option:active { background: #EDE8FF; }
.option-selected { background: #F0EEFF; border-color: #6C5CE7; }
.option-marker { width: 52rpx; height: 52rpx; border-radius: 50%; background: #FFF; display: flex; align-items: center; justify-content: center; font-size: 26rpx; font-weight: 700; color: #636E72; margin-right: 16rpx; border: 2rpx solid #DDD; flex-shrink: 0; }
.option-selected .option-marker { background: #6C5CE7; color: #FFF; border-color: #6C5CE7; }
.option-text { flex: 1; font-size: 28rpx; color: #2D3436; }
.q-input { width: 100%; min-height: 200rpx; background: #F8F9FA; border-radius: 14rpx; padding: 20rpx; font-size: 28rpx; box-sizing: border-box; }
.take-actions { display: flex; gap: 20rpx; }
.take-actions .btn-secondary, .take-actions .btn-primary { flex: 1; font-size: 28rpx; padding: 22rpx; }
