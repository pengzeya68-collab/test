<view class="container">
  <view class="result-card card">
    <text class="result-emoji">{{result.passed ? '🎉' : '😔'}}</text>
    <text class="result-title">{{result.passed ? '恭喜通过！' : '未通过'}}</text>
    <text class="result-score">{{result.score || 0}}<text class="result-total">/{{result.total_score || 100}}</text></text>
  </view>

  <view class="card">
    <view class="card-title"><text>📊 成绩详情</text></view>
    <view class="detail-grid">
      <view class="detail-item">
        <text class="detail-value text-success">{{result.correct_count || 0}}</text>
        <text class="detail-label">正确</text>
      </view>
      <view class="detail-item">
        <text class="detail-value text-danger">{{result.wrong_count || 0}}</text>
        <text class="detail-label">错误</text>
      </view>
      <view class="detail-item">
        <text class="detail-value">{{result.total_count || 0}}</text>
        <text class="detail-label">总题数</text>
      </view>
      <view class="detail-item">
        <text class="detail-value text-primary">{{result.accuracy || '0%'}}</text>
        <text class="detail-label">正确率</text>
      </view>
    </view>
  </view>

  <view class="btn-group">
    <button class="btn-primary" bindtap="goBack">返回</button>
  </view>
</view>
