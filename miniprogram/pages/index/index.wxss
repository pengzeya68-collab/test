.home-page {
  background: #F8F9FA;
  min-height: 100vh;
  padding-bottom: 120rpx;
}

.header-card {
  background: linear-gradient(135deg, #6C5CE7, #A29BFE);
  padding: 40rpx 30rpx 30rpx;
  position: relative;
  overflow: hidden;
}

.header-bg {
  position: absolute;
  top: -60rpx;
  right: -60rpx;
  width: 300rpx;
  height: 300rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.08);
}

.header-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.greeting {
  display: flex;
  flex-direction: column;
}

.greeting-text {
  font-size: 38rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.greeting-sub {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 6rpx;
}

.avatar-wrap {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.25);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 3rpx solid rgba(255, 255, 255, 0.4);
}

.avatar-text {
  font-size: 36rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.stats-row {
  display: flex;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 20rpx;
  padding: 24rpx 0;
  backdrop-filter: blur(10px);
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 800;
  color: #FFFFFF;
}

.stat-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.75);
  margin-top: 4rpx;
}

.stat-divider {
  width: 2rpx;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.2);
  align-self: center;
}

.quick-actions {
  display: flex;
  justify-content: space-around;
  padding: 30rpx 20rpx;
  margin: -30rpx 30rpx 0;
  background: #FFFFFF;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.08);
  position: relative;
  z-index: 1;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.action-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-bottom: 12rpx;
}

.action-label {
  font-size: 24rpx;
  color: #636E72;
  font-weight: 500;
}

.section {
  padding: 30rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #2D3436;
}

.section-more {
  font-size: 26rpx;
  color: #6C5CE7;
}

.empty-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.empty-icon-text {
  font-size: 60rpx;
  margin-bottom: 16rpx;
}

.empty-hint {
  font-size: 28rpx;
  color: #999;
}

.exercise-card {
  display: flex;
  flex-direction: column;
}

.exercise-card-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 12rpx;
}

.exercise-title {
  flex: 1;
  font-size: 30rpx;
  font-weight: 600;
  color: #2D3436;
  margin-right: 16rpx;
}

.exercise-card-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.exercise-category {
  font-size: 24rpx;
  color: #999;
}

.exercise-type {
  font-size: 22rpx;
  color: #6C5CE7;
  background: #F0EEFF;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

.daily-card {
  position: relative;
  overflow: hidden;
}

.daily-badge {
  position: absolute;
  top: 0;
  right: 0;
  background: linear-gradient(135deg, #6C5CE7, #A29BFE);
  color: #FFFFFF;
  font-size: 22rpx;
  padding: 8rpx 20rpx;
  border-radius: 0 20rpx 0 16rpx;
  font-weight: 600;
}

.daily-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #2D3436;
  margin-bottom: 12rpx;
  padding-right: 120rpx;
}

.daily-desc {
  font-size: 26rpx;
  color: #636E72;
  margin-bottom: 20rpx;
  line-height: 1.6;
}

.daily-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.daily-action {
  font-size: 28rpx;
  color: #6C5CE7;
  font-weight: 600;
}

.loading-state {
  text-align: center;
  padding: 60rpx;
  color: #999;
  font-size: 28rpx;
}

.error-tip {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #FFF3CD;
  border-radius: 16rpx;
  padding: 20rpx 30rpx;
  margin: 20rpx 30rpx;
}

.error-tip-text {
  font-size: 26rpx;
  color: #856404;
}

.error-tip-retry {
  font-size: 26rpx;
  color: #6C5CE7;
  font-weight: 600;
}
