.tabs { display: flex; background: #fff; border-radius: 12rpx; margin-bottom: 24rpx; overflow: hidden; }
.tab { flex: 1; text-align: center; padding: 20rpx 0; font-size: 28rpx; color: #666; border-bottom: 4rpx solid transparent; }
.tab.active { color: #4F46E5; border-bottom-color: #4F46E5; font-weight: 600; }
.fav-card { margin-bottom: 16rpx; }
.fav-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 8rpx; }
.fav-title { font-size: 30rpx; font-weight: 500; color: #1a1a1a; }
