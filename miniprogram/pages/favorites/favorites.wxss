.fav-page { background: #F8F9FA; min-height: 100vh; padding: 20rpx 30rpx; }
.fav-scroll { height: calc(100vh - 40rpx); }
.fav-item { margin-bottom: 20rpx; }
.fav-top { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 12rpx; }
.fav-title { flex: 1; font-size: 30rpx; font-weight: 600; color: #2D3436; margin-right: 16rpx; line-height: 1.5; }
.fav-unfav { padding: 8rpx; font-size: 32rpx; }
.fav-bottom { display: flex; justify-content: space-between; align-items: center; }
.fav-category { font-size: 24rpx; color: #6C5CE7; background: #F0EEFF; padding: 4rpx 14rpx; border-radius: 6rpx; }
.fav-time { font-size: 22rpx; color: #B2BEC3; }
.loading-state { text-align: center; padding: 60rpx; color: #999; }
.empty-state { display: flex; flex-direction: column; align-items: center; padding: 120rpx 40rpx; }
.empty-icon { font-size: 80rpx; margin-bottom: 20rpx; }
.empty-text { font-size: 28rpx; color: #999; }
