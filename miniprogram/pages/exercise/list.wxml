<view class="page">
  <view class="search-wrap">
    <view class="search-box">
      <text class="search-icon">🔍</text>
      <input class="search-input" placeholder="搜索习题..." placeholder-class="search-placeholder" value="{{keyword}}" bindinput="onSearch" confirm-type="search" bindconfirm="doSearch" />
    </view>
  </view>

  <view class="filter-row">
    <view class="filter-btn {{filter.category ? 'filter-active' : ''}}" bindtap="showCategoryPicker">
      <text class="filter-text">{{filter.categoryName || '分类'}}</text>
      <text class="filter-arrow">▾</text>
    </view>
    <view class="filter-btn {{filter.difficulty ? 'filter-active' : ''}}" bindtap="showDifficultyPicker">
      <text class="filter-text">{{filter.difficultyName || '难度'}}</text>
      <text class="filter-arrow">▾</text>
    </view>
    <view class="filter-btn {{filter.status ? 'filter-active' : ''}}" bindtap="showStatusPicker">
      <text class="filter-text">{{filter.statusName || '状态'}}</text>
      <text class="filter-arrow">▾</text>
    </view>
  </view>

  <view wx:if="{{loading && exercises.length === 0}}" class="loading-box">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <view wx:if="{{!loading && exercises.length === 0}}" class="empty-box">
    <text class="empty-emoji">📝</text>
    <text class="empty-title">暂无习题</text>
    <text class="empty-sub">换个筛选条件试试吧</text>
  </view>

  <view class="card-list">
    <view class="ex-card" wx:for="{{exercises}}" wx:key="id" bindtap="goDetail" data-id="{{item.id}}" hover-class="ex-card-hover">
      <view class="ex-card-top">
        <view class="ex-tags">
          <view class="tag-difficulty tag-{{item.difficultyTag.cls}}">{{item.difficultyTag.text}}</view>
          <view class="tag-category" wx:if="{{item.category}}">{{item.category}}</view>
          <view class="tag-lang" wx:if="{{item.language}}">{{item.language}}</view>
        </view>
        <view class="ex-status" wx:if="{{item.is_completed}}">
          <text class="status-dot {{item.is_correct ? 'dot-correct' : 'dot-wrong'}}"></text>
          <text class="status-label {{item.is_correct ? 'label-correct' : 'label-wrong'}}">{{item.is_correct ? '正确' : '错误'}}</text>
        </view>
      </view>
      <text class="ex-title">{{item.title}}</text>
      <view class="ex-card-bottom">
        <text class="ex-type">{{item.type || '选择题'}}</text>
      </view>
    </view>
  </view>

  <view class="load-more-wrap" wx:if="{{hasMore}}" bindtap="loadMore">
    <text class="load-more-text">{{loading ? '加载中...' : '点击加载更多'}}</text>
  </view>
</view>
