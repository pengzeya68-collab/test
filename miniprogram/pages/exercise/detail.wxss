.page {
  min-height: 100vh;
  background: #F8F9FA;
  padding: 24rpx;
  padding-bottom: 160rpx;
}

.header-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.header-tags {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.tag-difficulty {
  display: inline-block;
  padding: 6rpx 18rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.tag-tag-easy {
  background: #E8F8F5;
  color: #00B894;
}

.tag-tag-medium {
  background: #FFF9E6;
  color: #E17055;
}

.tag-tag-hard {
  background: #FFF0F0;
  color: #FF6B6B;
}

.tag-tag-pending {
  background: #F3F4F6;
  color: #6B7280;
}

.tag-category {
  display: inline-block;
  padding: 6rpx 18rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 500;
  background: #F0EDFF;
  color: #6C5CE7;
}

.header-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1a1a1a;
  line-height: 1.6;
}

.desc-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.desc-label {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #6C5CE7;
  margin-bottom: 16rpx;
}

.desc-content {
  display: block;
  font-size: 28rpx;
  color: #444;
  line-height: 1.8;
  background: #F8F9FA;
  border-radius: 12rpx;
  padding: 20rpx;
}

.options-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.options-label {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #6C5CE7;
  margin-bottom: 20rpx;
}

.options-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.option-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-radius: 12rpx;
  border: 2rpx solid #E0E0E0;
  background: #fff;
  transition: all 0.25s;
}

.option-selected {
  border-color: #6C5CE7;
  background: #F0EDFF;
}

.option-correct {
  border-color: #00B894;
  background: #E8F8F5;
}

.option-wrong {
  border-color: #FF6B6B;
  background: #FFF0F0;
}

.option-circle {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: #F0F0F0;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
  transition: all 0.25s;
}

.circle-selected {
  background: #6C5CE7;
}

.circle-correct {
  background: #00B894;
}

.circle-wrong {
  background: #FF6B6B;
}

.option-letter {
  font-size: 26rpx;
  font-weight: 700;
  color: #666;
}

.circle-selected .option-letter {
  color: #fff;
}

.circle-correct .option-letter {
  color: #fff;
}

.circle-wrong .option-letter {
  color: #fff;
}

.option-text {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
}

.option-check {
  font-size: 32rpx;
  color: #00B894;
  font-weight: 700;
  margin-left: 12rpx;
}

.option-cross {
  font-size: 32rpx;
  color: #FF6B6B;
  font-weight: 700;
  margin-left: 12rpx;
}

.result-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.result-banner {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
}

.banner-correct {
  background: #E8F8F5;
}

.banner-wrong {
  background: #FFF0F0;
}

.result-emoji {
  font-size: 44rpx;
  margin-right: 16rpx;
}

.result-title {
  font-size: 32rpx;
  font-weight: 700;
}

.banner-correct .result-title {
  color: #00B894;
}

.banner-wrong .result-title {
  color: #FF6B6B;
}

.explanation-box {
  padding: 20rpx;
  background: #FFF9E6;
  border-radius: 12rpx;
}

.explanation-label {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #E17055;
  margin-bottom: 10rpx;
}

.explanation-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.8;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.06);
  z-index: 100;
}

.btn-submit {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #6C5CE7, #A29BFE);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  border-radius: 44rpx;
  text-align: center;
}

.btn-submit::after {
  border: none;
}

.btn-submit[disabled] {
  background: #D5D3E8;
  color: #fff;
}

.btn-next {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #6C5CE7, #A29BFE);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  border-radius: 44rpx;
  text-align: center;
}

.btn-next::after {
  border: none;
}
