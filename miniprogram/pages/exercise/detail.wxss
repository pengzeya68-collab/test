.detail-page {
  background: #F8F9FA;
  min-height: 100vh;
  padding: 20rpx 30rpx 40rpx;
}

.error-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 40rpx;
}

.error-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.error-text {
  font-size: 30rpx;
  color: #999;
  margin-bottom: 40rpx;
}

.error-state .btn-primary {
  padding: 16rpx 60rpx;
  font-size: 28rpx;
}

.detail-header {
  margin-bottom: 20rpx;
}

.detail-top {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.detail-category {
  font-size: 24rpx;
  color: #6C5CE7;
  background: #F0EEFF;
  padding: 4rpx 14rpx;
  border-radius: 6rpx;
}

.tag-type {
  background: #FFF3CD;
  color: #856404;
}

.detail-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #2D3436;
  line-height: 1.5;
  margin-bottom: 16rpx;
}

.detail-meta {
  display: flex;
  gap: 24rpx;
  font-size: 24rpx;
  color: #999;
}

.body-section {
  margin-bottom: 24rpx;
}

.body-section:last-child {
  margin-bottom: 0;
}

.section-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #6C5CE7;
  margin-bottom: 12rpx;
  display: block;
}

.section-content {
  font-size: 28rpx;
  color: #2D3436;
  line-height: 1.8;
  white-space: pre-wrap;
}

.answer-section {
  margin-bottom: 20rpx;
}

.sql-input, .answer-input {
  width: 100%;
  min-height: 200rpx;
  background: #F8F9FA;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 28rpx;
  color: #2D3436;
  margin-bottom: 20rpx;
  box-sizing: border-box;
  line-height: 1.6;
  font-family: 'Courier New', monospace;
}

.sql-actions {
  display: flex;
  gap: 20rpx;
}

.sql-actions .btn-secondary, .sql-actions .btn-primary {
  flex: 1;
  font-size: 28rpx;
  padding: 20rpx;
}

.submit-btn {
  width: 100%;
  margin-top: 10rpx;
}

.sql-result {
  margin-top: 24rpx;
  background: #F8F9FA;
  border-radius: 16rpx;
  padding: 24rpx;
}

.result-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.status-success {
  color: #00B894;
  font-weight: 600;
}

.status-fail {
  color: #E17055;
  font-weight: 600;
}

.result-time {
  font-size: 24rpx;
  color: #999;
}

.result-table {
  overflow-x: auto;
}

.table-header {
  display: flex;
  background: #6C5CE7;
  border-radius: 8rpx 8rpx 0 0;
}

.table-row {
  display: flex;
  border-bottom: 1rpx solid #EEE;
}

.table-row:nth-child(even) {
  background: #F0EEFF;
}

.table-cell {
  flex: 1;
  padding: 12rpx 16rpx;
  font-size: 24rpx;
  color: #2D3436;
  min-width: 120rpx;
}

.table-header .table-cell {
  color: #FFFFFF;
  font-weight: 600;
}

.result-error {
  color: #E17055;
  font-size: 26rpx;
}

.result-msg {
  color: #636E72;
  font-size: 26rpx;
}

.result-card {
  overflow: hidden;
}

.result-banner {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
}

.banner-success {
  background: #D4EDDA;
}

.banner-fail {
  background: #F8D7DA;
}

.result-icon {
  font-size: 40rpx;
}

.result-text {
  font-size: 32rpx;
  font-weight: 700;
}

.expected-solution {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #EEE;
}

.solution-text {
  font-size: 28rpx;
  color: #2D3436;
  line-height: 1.8;
  white-space: pre-wrap;
}

.result-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 24rpx;
}

.result-actions .btn-secondary,
.result-actions .btn-primary {
  flex: 1;
  font-size: 28rpx;
  padding: 20rpx;
}

.choice-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.choice-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #F8F9FA;
  border-radius: 16rpx;
  border: 3rpx solid transparent;
  transition: all 0.2s;
}

.choice-item:active {
  background: #EDE8FF;
}

.choice-selected {
  background: #F0EEFF;
  border-color: #6C5CE7;
}

.choice-correct {
  border-color: #00B894 !important;
  background: #E8F8F0 !important;
}

.choice-wrong {
  border-color: #E17055 !important;
  background: #FFF5F5 !important;
}

.choice-marker {
  width: 52rpx;
  height: 52rpx;
  border-radius: 10rpx;
  background: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 700;
  color: #636E72;
  margin-right: 20rpx;
  flex-shrink: 0;
  border: 2rpx solid #DDD;
}

.choice-selected .choice-marker {
  background: #6C5CE7;
  color: #FFFFFF;
  border-color: #6C5CE7;
}

.marker-radio {
  border-radius: 50%;
}

.marker-radio-checked {
  border-radius: 50%;
  background: #6C5CE7;
  border-color: #6C5CE7;
  position: relative;
}

.radio-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: #FFFFFF;
}

.marker-checkbox {
  border-radius: 10rpx;
}

.marker-checkbox-checked {
  border-radius: 10rpx;
  background: #6C5CE7;
  border-color: #6C5CE7;
  color: #FFFFFF;
  font-size: 28rpx;
}

.choice-text {
  flex: 1;
  font-size: 28rpx;
  color: #2D3436;
  line-height: 1.6;
}

.choice-icon {
  margin-left: 12rpx;
  font-size: 30rpx;
}

.wrong-icon {
  color: #E17055;
}

.selected-hint {
  font-size: 24rpx;
  color: #6C5CE7;
  margin-bottom: 16rpx;
  padding: 8rpx 16rpx;
  background: #F0EEFF;
  border-radius: 8rpx;
}
