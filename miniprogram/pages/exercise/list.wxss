.page {
  min-height: 100vh;
  background: #F8F9FA;
  padding: 24rpx;
  padding-bottom: 120rpx;
}

.search-wrap {
  margin-bottom: 24rpx;
}

.search-box {
  display: flex;
  align-items: center;
  height: 72rpx;
  background: #F0EDFF;
  border-radius: 36rpx;
  padding: 0 28rpx;
}

.search-icon {
  font-size: 28rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  height: 72rpx;
  font-size: 28rpx;
  color: #333;
  background: transparent;
}

.search-placeholder {
  color: #A29BFE;
  font-size: 28rpx;
}

.filter-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 28rpx;
}

.filter-btn {
  display: flex;
  align-items: center;
  padding: 14rpx 24rpx;
  background: #fff;
  border-radius: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
  transition: all 0.2s;
}

.filter-btn.filter-active {
  background: #F0EDFF;
  box-shadow: 0 2rpx 12rpx rgba(108, 92, 231, 0.15);
}

.filter-text {
  font-size: 26rpx;
  color: #666;
  margin-right: 6rpx;
}

.filter-active .filter-text {
  color: #6C5CE7;
  font-weight: 500;
}

.filter-arrow {
  font-size: 20rpx;
  color: #999;
}

.filter-active .filter-arrow {
  color: #6C5CE7;
}

.loading-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid #E0E0E0;
  border-top-color: #6C5CE7;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 26rpx;
  color: #999;
}

.empty-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.empty-emoji {
  font-size: 96rpx;
  margin-bottom: 24rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.empty-sub {
  font-size: 26rpx;
  color: #999;
}

.card-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.ex-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
  transition: all 0.2s;
}

.ex-card-hover {
  transform: scale(0.98);
  box-shadow: 0 1rpx 6rpx rgba(0, 0, 0, 0.06);
}

.ex-card-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.ex-tags {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-wrap: wrap;
}

.tag-difficulty {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.tag-tag-easy {
  background: #E8F8F5;
  color: #00B894;
}

.tag-tag-medium {
  background: #FFF9E6;
  color: #E17055;
}

.tag-tag-hard {
  background: #FFF0F0;
  color: #FF6B6B;
}

.tag-tag-pending {
  background: #F3F4F6;
  color: #6B7280;
}

.tag-category {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 500;
  background: #F0EDFF;
  color: #6C5CE7;
}

.tag-lang {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 500;
  background: #E8F0FE;
  color: #4A90D9;
}

.ex-status {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.status-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
}

.dot-correct {
  background: #00B894;
}

.dot-wrong {
  background: #FF6B6B;
}

.status-label {
  font-size: 22rpx;
  font-weight: 500;
}

.label-correct {
  color: #00B894;
}

.label-wrong {
  color: #FF6B6B;
}

.ex-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
  line-height: 1.6;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.ex-card-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #F0F0F0;
}

.ex-type {
  font-size: 24rpx;
  color: #999;
}

.load-more-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.load-more-text {
  font-size: 26rpx;
  color: #6C5CE7;
}
