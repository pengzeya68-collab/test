<view class="lb-page">
  <view class="lb-tabs">
    <view class="lb-tab {{activeTab === 'score' ? 'lb-tab-active' : ''}}" bindtap="switchTab" data-tab="score">积分榜</view>
    <view class="lb-tab {{activeTab === 'weekly' ? 'lb-tab-active' : ''}}" bindtap="switchTab" data-tab="weekly">周榜</view>
    <view class="lb-tab {{activeTab === 'streak' ? 'lb-tab-active' : ''}}" bindtap="switchTab" data-tab="streak">连续签到</view>
  </view>

  <view class="top-three" wx:if="{{topList.length >= 3}}">
    <view class="top-item top-2">
      <view class="top-avatar"><text>🥈</text></view>
      <text class="top-name">{{topList[1].username || '-'}}</text>
      <text class="top-score">{{topList[1].score || topList[1].streak || 0}}</text>
    </view>
    <view class="top-item top-1">
      <view class="top-avatar"><text>🥇</text></view>
      <text class="top-name">{{topList[0].username || '-'}}</text>
      <text class="top-score">{{topList[0].score || topList[0].streak || 0}}</text>
    </view>
    <view class="top-item top-3">
      <view class="top-avatar"><text>🥉</text></view>
      <text class="top-name">{{topList[2].username || '-'}}</text>
      <text class="top-score">{{topList[2].score || topList[2].streak || 0}}</text>
    </view>
  </view>

  <view class="rank-list">
    <view class="rank-item card" wx:for="{{rankList}}" wx:key="id" wx:if="{{index >= 3}}">
      <text class="rank-num">{{index + 1}}</text>
      <text class="rank-name">{{item.username || '-'}}</text>
      <text class="rank-score">{{item.score || item.streak || 0}}</text>
    </view>
  </view>

  <view wx:if="{{loading}}" class="loading-state"><text>加载中...</text></view>
  <view wx:elif="{{rankList.length === 0 && !loading}}" class="empty-state">
    <text class="empty-icon">🏆</text>
    <text class="empty-text">暂无排行数据</text>
  </view>
</view>
