<view class="page">
  <view class="page-header">
    <view class="header-left">
      <text class="header-icon">🤖</text>
      <text class="header-title">自动化测试</text>
    </view>
    <text class="header-link" bindtap="goHistory">执行历史</text>
  </view>

  <view class="env-card">
    <text class="env-label">当前环境</text>
    <picker mode="selector" range="{{environments}}" range-key="name" value="{{envIndex}}" bindchange="onEnvChange">
      <view class="env-picker">
        <text class="env-value">{{environments[envIndex].name || '请选择'}}</text>
        <text class="env-arrow">▾</text>
      </view>
    </picker>
  </view>

  <view class="search-wrap">
    <view class="search-box">
      <text class="search-icon">🔍</text>
      <input class="search-input" placeholder="搜索场景..." placeholder-class="search-placeholder" value="{{keyword}}" bindinput="onSearch" />
    </view>
  </view>

  <view wx:if="{{loading && scenarios.length === 0}}" class="loading-box">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <view wx:if="{{!loading && scenarios.length === 0}}" class="empty-box">
    <text class="empty-emoji">🧪</text>
    <text class="empty-title">暂无测试场景</text>
    <text class="empty-sub">创建场景后即可开始测试</text>
  </view>

  <view class="scenario-list">
    <view class="scene-card" wx:for="{{scenarios}}" wx:key="id" hover-class="scene-card-hover">
      <view class="scene-top">
        <view class="scene-name-row">
          <text class="scene-name">{{item.name}}</text>
          <view class="scene-tag {{item.enabled !== false ? 'tag-on' : 'tag-off'}}">
            {{item.enabled !== false ? '启用' : '禁用'}}
          </view>
        </view>
      </view>

      <text class="scene-desc" wx:if="{{item.description}}">{{item.description}}</text>

      <view class="scene-meta">
        <view class="meta-item">
          <text class="meta-icon">📋</text>
          <text class="meta-text">{{item.step_count || 0}} 个步骤</text>
        </view>
        <view class="meta-item" wx:if="{{item.last_run}}">
          <text class="meta-icon">🕐</text>
          <text class="meta-text">{{item.last_run}}</text>
        </view>
      </view>

      <view class="scene-actions">
        <button class="btn-run" bindtap="runScenario" data-id="{{item.id}}" data-name="{{item.name}}" disabled="{{item.enabled === false || running}}">
          ▶ 执行
        </button>
        <button class="btn-outline" bindtap="goDetail" data-id="{{item.id}}">详情</button>
        <button class="btn-outline" bindtap="goHistory" data-id="{{item.id}}">历史</button>
      </view>
    </view>
  </view>

  <view class="load-more-wrap" wx:if="{{hasMore}}" bindtap="loadMore">
    <text class="load-more-text">{{loading ? '加载中...' : '点击加载更多'}}</text>
  </view>
</view>
