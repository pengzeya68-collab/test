.page {
  min-height: 100vh;
  background: #F8F9FA;
  padding: 24rpx;
  padding-bottom: 120rpx;
}

.page-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.header-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.header-icon {
  font-size: 40rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1a1a1a;
}

.header-link {
  font-size: 26rpx;
  color: #6C5CE7;
  font-weight: 500;
}

.env-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.env-label {
  font-size: 28rpx;
  color: #666;
  font-weight: 500;
  flex-shrink: 0;
  margin-right: 20rpx;
}

.env-picker {
  display: flex;
  align-items: center;
  padding: 14rpx 24rpx;
  background: #F0EDFF;
  border-radius: 24rpx;
  min-width: 280rpx;
}

.env-value {
  flex: 1;
  font-size: 28rpx;
  color: #6C5CE7;
  font-weight: 500;
}

.env-arrow {
  font-size: 22rpx;
  color: #6C5CE7;
  margin-left: 12rpx;
}

.search-wrap {
  margin-bottom: 24rpx;
}

.search-box {
  display: flex;
  align-items: center;
  height: 72rpx;
  background: #F0EDFF;
  border-radius: 36rpx;
  padding: 0 28rpx;
}

.search-icon {
  font-size: 28rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  height: 72rpx;
  font-size: 28rpx;
  color: #333;
  background: transparent;
}

.search-placeholder {
  color: #A29BFE;
  font-size: 28rpx;
}

.loading-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid #E0E0E0;
  border-top-color: #6C5CE7;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 26rpx;
  color: #999;
}

.empty-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.empty-emoji {
  font-size: 96rpx;
  margin-bottom: 24rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.empty-sub {
  font-size: 26rpx;
  color: #999;
}

.scenario-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.scene-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
  transition: all 0.2s;
}

.scene-card-hover {
  transform: scale(0.98);
}

.scene-top {
  margin-bottom: 12rpx;
}

.scene-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.scene-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a1a;
  flex: 1;
}

.scene-tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.tag-on {
  background: #E8F8F5;
  color: #00B894;
}

.tag-off {
  background: #F3F4F6;
  color: #6B7280;
}

.scene-desc {
  display: block;
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
  margin-bottom: 16rpx;
}

.scene-meta {
  display: flex;
  align-items: center;
  gap: 28rpx;
  padding: 16rpx 0;
  border-top: 1rpx solid #F0F0F0;
  border-bottom: 1rpx solid #F0F0F0;
  margin-bottom: 20rpx;
}

.meta-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.meta-icon {
  font-size: 24rpx;
}

.meta-text {
  font-size: 24rpx;
  color: #999;
}

.scene-actions {
  display: flex;
  gap: 16rpx;
}

.btn-run {
  margin: 0;
  padding: 14rpx 32rpx;
  background: linear-gradient(135deg, #6C5CE7, #A29BFE);
  color: #fff;
  border: none;
  border-radius: 32rpx;
  font-size: 26rpx;
  font-weight: 600;
  line-height: normal;
}

.btn-run::after {
  border: none;
}

.btn-run[disabled] {
  background: #D5D3E8;
  color: #fff;
}

.btn-outline {
  margin: 0;
  padding: 14rpx 28rpx;
  background: #fff;
  color: #6C5CE7;
  border: 2rpx solid #6C5CE7;
  border-radius: 32rpx;
  font-size: 26rpx;
  font-weight: 500;
  line-height: normal;
}

.btn-outline::after {
  border: none;
}

.load-more-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.load-more-text {
  font-size: 26rpx;
  color: #6C5CE7;
}
