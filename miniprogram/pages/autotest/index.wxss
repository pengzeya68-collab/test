.autotest-page {
  background: #F8F9FA;
  min-height: 100vh;
  padding-bottom: 120rpx;
}

.page-header {
  background: linear-gradient(135deg, #00B894, #55EFC4);
  padding: 40rpx 30rpx 50rpx;
}

.page-title {
  font-size: 42rpx;
  font-weight: 800;
  color: #FFFFFF;
  display: block;
}

.page-subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-top: 6rpx;
  display: block;
}

.action-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  padding: 0 30rpx;
  margin-top: -30rpx;
  position: relative;
  z-index: 1;
}

.grid-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx 20rpx;
}

.grid-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-bottom: 14rpx;
}

.grid-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #2D3436;
  margin-bottom: 4rpx;
}

.grid-desc {
  font-size: 22rpx;
  color: #999;
}

.section {
  padding: 30rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #2D3436;
}

.section-more {
  font-size: 26rpx;
  color: #6C5CE7;
}

.empty-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 50rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.empty-icon-text {
  font-size: 60rpx;
  margin-bottom: 16rpx;
}

.empty-hint {
  font-size: 28rpx;
  color: #999;
}

.task-card {
  padding: 24rpx;
}

.task-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.task-name {
  flex: 1;
  font-size: 28rpx;
  font-weight: 600;
  color: #2D3436;
}

.task-status {
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 6rpx;
  font-weight: 500;
}

.status-running {
  background: #FFF3CD;
  color: #856404;
}

.status-completed {
  background: #D4EDDA;
  color: #155724;
}

.status-failed {
  background: #F8D7DA;
  color: #721C24;
}

.task-bottom {
  display: flex;
  justify-content: space-between;
}

.task-time {
  font-size: 22rpx;
  color: #B2BEC3;
}

.scenario-card {
  padding: 24rpx;
}

.scenario-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.scenario-name {
  flex: 1;
  font-size: 28rpx;
  font-weight: 600;
  color: #2D3436;
  margin-right: 16rpx;
}

.run-btn {
  background: #6C5CE7 !important;
  color: #FFFFFF !important;
  border-radius: 8rpx !important;
  font-size: 24rpx !important;
  padding: 8rpx 20rpx !important;
  line-height: 1.4 !important;
}

.scenario-desc {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.scenario-meta {
  font-size: 22rpx;
  color: #B2BEC3;
}
