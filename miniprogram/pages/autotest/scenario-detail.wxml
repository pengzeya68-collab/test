<view class="container">
  <view class="card">
    <view class="scenario-title-row">
      <text class="scenario-title">{{scenario.name}}</text>
      <view class="tag {{scenario.enabled !== false ? 'tag-pass' : 'tag-pending'}}">
        {{scenario.enabled !== false ? '启用' : '禁用'}}
      </view>
    </view>
    <text class="text-muted text-sm" wx:if="{{scenario.description}}">{{scenario.description}}</text>
  </view>

  <view class="card">
    <view class="card-title"><text>📋 场景步骤 ({{steps.length}})</text></view>
    <view wx:if="{{steps.length === 0}}" class="empty-state">
      <text class="empty-text">暂无步骤</text>
    </view>
    <view class="step-list">
      <view class="step-item" wx:for="{{steps}}" wx:key="id">
        <view class="step-order">{{index + 1}}</view>
        <view class="step-info">
          <text class="step-name">{{item.name || item.case_name || ('步骤 ' + (index + 1))}}</text>
          <text class="step-detail text-muted text-sm">{{item.method || ''}} {{item.url || item.path || ''}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="card">
    <view class="card-title"><text>⚡ 快捷操作</text></view>
    <view class="action-grid">
      <button class="btn-primary" bindtap="runScenario" disabled="{{scenario.enabled === false}}">▶ 执行场景</button>
      <button class="btn-secondary" bindtap="goHistory">查看历史</button>
    </view>
  </view>
</view>
