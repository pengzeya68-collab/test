.sc-page { background: #F8F9FA; min-height: 100vh; }
.search-bar { padding: 20rpx 30rpx; background: #FFF; }
.search-wrap { display: flex; align-items: center; background: #F0EEFF; border-radius: 40rpx; padding: 0 24rpx; height: 76rpx; }
.search-icon { font-size: 28rpx; margin-right: 12rpx; }
.search-input { flex: 1; font-size: 28rpx; }
.search-clear { font-size: 28rpx; color: #999; padding: 0 8rpx; }
.sc-scroll { padding: 20rpx 30rpx; height: calc(100vh - 120rpx); }
.sc-item { margin-bottom: 20rpx; }
.sc-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 10rpx; }
.sc-name { flex: 1; font-size: 30rpx; font-weight: 600; color: #2D3436; margin-right: 16rpx; }
.sc-status { font-size: 22rpx; padding: 4rpx 14rpx; border-radius: 6rpx; font-weight: 500; }
.status-active { background: #D4EDDA; color: #155724; }
.status-running { background: #FFF3CD; color: #856404; }
.status-draft { background: #F0F0F0; color: #999; }
.sc-desc { font-size: 26rpx; color: #999; margin-bottom: 12rpx; }
.sc-bottom { display: flex; justify-content: space-between; align-items: center; }
.sc-meta { font-size: 22rpx; color: #B2BEC3; }
.sc-run-btn { background: #6C5CE7 !important; color: #FFF !important; border-radius: 8rpx !important; font-size: 24rpx !important; }
.loading-state { text-align: center; padding: 60rpx; color: #999; }
.empty-state { display: flex; flex-direction: column; align-items: center; padding: 120rpx 40rpx; }
.empty-icon { font-size: 80rpx; margin-bottom: 20rpx; }
.empty-text { font-size: 28rpx; color: #999; }
.no-more { text-align: center; padding: 30rpx; color: #CCC; font-size: 24rpx; }
