.filter-bar { display: flex; gap: 16rpx; margin-bottom: 24rpx; }
.filter-item { padding: 12rpx 28rpx; background: #fff; border-radius: 20rpx; font-size: 26rpx; color: #666; border: 2rpx solid #E5E7EB; }
.filter-item.active { background: #EEF2FF; color: #4F46E5; border-color: #4F46E5; }
.history-card { margin-bottom: 16rpx; }
.history-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 8rpx; }
.history-name { font-size: 30rpx; font-weight: 600; color: #1a1a1a; flex: 1; }
.history-meta { display: flex; gap: 24rpx; margin: 8rpx 0; }
.history-stats { margin-top: 8rpx; padding-top: 8rpx; border-top: 1rpx solid #F5F5F5; }
.load-more { text-align: center; padding: 30rpx; }
