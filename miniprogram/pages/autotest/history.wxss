.hist-page { background: #F8F9FA; min-height: 100vh; }
.hist-tabs { display: flex; background: #FFF; padding: 20rpx 30rpx; gap: 16rpx; }
.hist-tab { flex: 1; text-align: center; padding: 14rpx 0; border-radius: 12rpx; font-size: 26rpx; font-weight: 600; color: #636E72; background: #F0F0F0; }
.hist-tab-active { background: #6C5CE7; color: #FFF; }
.hist-scroll { padding: 20rpx 30rpx; height: calc(100vh - 120rpx); }
.hist-item { margin-bottom: 16rpx; }
.hist-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 10rpx; }
.hist-name { flex: 1; font-size: 28rpx; font-weight: 600; color: #2D3436; margin-right: 16rpx; }
.hist-status { font-size: 24rpx; padding: 4rpx 14rpx; border-radius: 6rpx; font-weight: 500; white-space: nowrap; }
.status-running { background: #FFF3CD; color: #856404; }
.status-completed { background: #D4EDDA; color: #155724; }
.status-failed { background: #F8D7DA; color: #721C24; }
.hist-info { display: flex; gap: 24rpx; font-size: 24rpx; color: #636E72; margin-bottom: 8rpx; }
.hist-time { font-size: 22rpx; color: #B2BEC3; }
.loading-state { text-align: center; padding: 60rpx; color: #999; }
.empty-state { display: flex; flex-direction: column; align-items: center; padding: 120rpx 40rpx; }
.empty-icon { font-size: 80rpx; margin-bottom: 20rpx; }
.empty-text { font-size: 28rpx; color: #999; }
.no-more { text-align: center; padding: 30rpx; color: #CCC; font-size: 24rpx; }
