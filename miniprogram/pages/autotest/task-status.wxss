.task-title-row { display: flex; align-items: center; gap: 12rpx; margin-bottom: 8rpx; }
.task-name { font-size: 34rpx; font-weight: 700; color: #1a1a1a; flex: 1; }
.task-id { margin-top: 4rpx; }

.progress-card { position: relative; }
.progress-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx; }
.progress-label { font-size: 28rpx; font-weight: 500; color: #333; }
.progress-percent { font-size: 32rpx; font-weight: 700; color: #4F46E5; }
.progress-bar { height: 16rpx; background: #E5E7EB; border-radius: 8rpx; overflow: hidden; }
.progress-fill { height: 100%; background: linear-gradient(90deg, #4F46E5, #7C3AED); border-radius: 8rpx; transition: width 0.5s ease; }
.progress-step { margin-top: 12rpx; display: block; }

.result-grid { display: flex; }
.result-item { flex: 1; display: flex; flex-direction: column; align-items: center; padding: 16rpx 0; }
.result-value { font-size: 36rpx; font-weight: 700; }
.result-label { font-size: 22rpx; color: #999; margin-top: 4rpx; }

.step-results { margin-top: 8rpx; }
.step-result-item { padding: 16rpx 0; border-bottom: 1rpx solid #F5F5F5; }
.step-result-item:last-child { border-bottom: none; }
.step-result-header { display: flex; align-items: center; gap: 12rpx; }
.step-result-order { width: 40rpx; height: 40rpx; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 22rpx; font-weight: 600; flex-shrink: 0; }
.order-pass { background: #ECFDF5; color: #059669; }
.order-fail { background: #FEF2F2; color: #DC2626; }
.step-result-name { flex: 1; font-size: 28rpx; font-weight: 500; color: #333; }
.step-result-detail { margin-top: 8rpx; padding-left: 52rpx; }

.btn-group { margin-top: 30rpx; display: flex; gap: 16rpx; padding-bottom: 40rpx; }
.btn-group button { flex: 1; margin: 0; }
