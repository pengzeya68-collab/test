<view class="custom-tab-bar">
  <view class="tab-item {{selected === 0 ? 'tab-active' : ''}}" bindtap="switchTab" data-index="0" data-url="/pages/index/index">
    <view class="tab-icon icon-home"></view>
    <text class="tab-text">首页</text>
  </view>
  <view class="tab-item {{selected === 1 ? 'tab-active' : ''}}" bindtap="switchTab" data-index="1" data-url="/pages/exercise/list">
    <view class="tab-icon icon-exercise"></view>
    <text class="tab-text">练习</text>
  </view>
  <view class="tab-item {{selected === 2 ? 'tab-active' : ''}}" bindtap="switchTab" data-index="2" data-url="/pages/autotest/index">
    <view class="tab-icon icon-autotest"></view>
    <text class="tab-text">自动化</text>
  </view>
  <view class="tab-item {{selected === 3 ? 'tab-active' : ''}}" bindtap="switchTab" data-index="3" data-url="/pages/profile/profile">
    <view class="tab-icon icon-profile"></view>
    <text class="tab-text">我的</text>
  </view>
</view>
