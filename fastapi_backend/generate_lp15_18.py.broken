# ========== LP17: AI测试与智能化 (50题) ==========
LP17_EXERCISES = [
    # AI测试概述 (8题)
    ("AI在软件测试中的主要应用场景包括哪些？",
     "AI在软件测试中的主要应用场景包括哪些？（多选）\n\nA. 自动化测试用例生成\nB. 视觉回归测试\nC. 缺陷预测\nD. 测试数据生成",
     "A,B,C,D', 'multiple_choice', 'easy', 'AI测试概述'AI测试概述"),
    ("AI辅助测试相比传统测试的主要优势是什么？",
     "AI辅助测试相比传统测试的主要优势是什么？\n\nA. 完全取代人工测试\nB. 提高测试效率，发现传统方法难以发现的模式\nC. 降低测试成本到零\nD. 不需要编写任何测试代码",
     "B', 'single_choice', 'easy', "AI测试概述'),
    ('以下哪个不是AI测试的常见挑战？',
     '以下哪个不是AI测试的常见挑战？\n\nA. 训练数据的质量和数量\nB. AI模型的可解释性\nC. AI模型需要持续维护和更新\nD. AI测试比传统测试更简单，没有任何挑战",
     "D', 'single_choice', 'easy', 'AI测试概述'AI测试概述"),
    ("AI测试的'测试左移'是什么意思？",
