# 项目配置
PROJECT_NAME=接口自动化测试平台
VERSION=1.0.0
ENVIRONMENT=development

# 数据库配置
DATABASE_URL=sqlite+aiosqlite:///./instance/testmaster.db

# JWT配置
SECRET_KEY=your-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# CORS配置
CORS_ORIGINS=["http://localhost:5173", "http://localhost:3000"]

# AI配置
AI_PROVIDER=openai
AI_API_KEY=your-openai-api-key-here
AI_BASE_URL=https://api.openai.com/v1  # 可选，用于自定义端点
AI_MODEL=gpt-4-turbo-preview
AI_TIMEOUT_SECONDS=30
AI_MAX_TOKENS=2000
AI_TEMPERATURE=0.7

# 沙盒配置
SANDBOX_DEFAULT_TIMEOUT_SECONDS=3
SANDBOX_MAX_TIMEOUT_SECONDS=30
SANDBOX_MAX_MEMORY_MB=256
# SANDBOX_ALLOWED_MODULES 可在代码中配置，暂不需要环境变量

# 服务器配置
HOST=0.0.0.0
PORT=5001
RELOAD=true
