{
    "name":  "testmaster-desktop",
    "version":  "1.0.0",
    "private":  true,
    "description":  "TestMaster Desktop - Enterprise Playwright UI automation",
    "author":  "TestMaster",
    "license":  "UNLICENSED",
    "main":  "dist/main/index.js",
    "scripts":  {
                    "dev":  "npm run build:main \u0026\u0026 electron .",
                    "build:main":  "tsc",
                    "build:renderer":  "node scripts/build-renderer.mjs \u0026\u0026 node scripts/copy-renderer.mjs",
                    "build":  "npm run build:main \u0026\u0026 npm run build:renderer",
                    "build:backend":  "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build-backend.ps1",
                    "build:pack":  "npm run build:backend \u0026\u0026 npm run build \u0026\u0026 electron-builder --win",
                    "test":  "vitest run",
                    "test:watch":  "vitest",
                    "typecheck":  "tsc --noEmit",
                    "postinstall":  "playwright install chromium"
                },
    "dependencies":  {
                         "@playwright/test":  "1.49.0",
                         "playwright":  "1.49.0",
                         "zod":  "3.23.0"
                     },
    "devDependencies":  {
                            "@types/node":  "20.11.0",
                            "electron":  "33.0.0",
                            "electron-builder":  "25.1.0",
                            "typescript":  "5.4.5",
                            "vitest":  "2.1.0"
                        }
}
