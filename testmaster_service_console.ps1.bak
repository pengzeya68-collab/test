# TestMaster 服务控制台 - 中文版
# 项目路径: C:\Users\lenovo\Desktop\TestMasterProject

$ProjectRoot = "C:\Users\lenovo\Desktop\TestMasterProject"
$RedisUrl = "redis://localhost:6379/0"

# 检查端口是否在监听
function Test-PortListening {
    param([int]$Port)
    $result = netstat -ano | Select-String ":$Port"
    return ($result | Select-String "LISTENING") -ne $null
}

# 检查Redis服务是否运行
function Test-RedisRunning {
    $svc = Get-Service -Name Redis -ErrorAction SilentlyContinue
    return $svc -and $svc.Status -eq "Running"
}

# 显示所有服务状态
function Show-Status {
    Write-Host ""
    Write-Host "=== 服务状态 ===" -ForegroundColor Cyan

    if (Test-RedisRunning) {
        Write-Host "[运行中] Redis 服务" -ForegroundColor Green
    } else {
        Write-Host "[已停止] Redis 服务" -ForegroundColor Yellow
    }

    if (Test-PortListening 5001) {
        Write-Host "[运行中] FastAPI 后端 (端口 5001)" -ForegroundColor Green
    } else {
        Write-Host "[已停止] FastAPI 后端 (端口 5001)" -ForegroundColor Yellow
    }

    if (Test-PortListening 5173) {
        Write-Host "[运行中] 前端 Vite (端口 5173)" -ForegroundColor Green
    } else {
        Write-Host "[已停止] 前端 Vite (端口 5173)" -ForegroundColor Yellow
    }

    Write-Host ""
}

# 启动Redis服务
function Start-RedisService {
    if (Test-RedisRunning) {
        Write-Host "Redis 已经在运行。" -ForegroundColor Yellow
        return
    }

    Write-Host "正在启动 Redis 服务..." -ForegroundColor Cyan
    try {
        Start-Service -Name Redis -ErrorAction Stop
        Write-Host "Redis 服务已启动。" -ForegroundColor Green
    } catch {
        Write-Host "无法启动 Redis 服务: $_" -ForegroundColor Red
        Write-Host "请确保 Redis 已安装为 Windows 服务。" -ForegroundColor Yellow
    }
}

# 停止Redis服务
function Stop-RedisService {
    if (-not (Test-RedisRunning)) {
        Write-Host "Redis 当前没有运行。" -ForegroundColor Yellow
        return
    }

    Write-Host "正在停止 Redis 服务..." -ForegroundColor Cyan
    try {
        Stop-Service -Name Redis -Force -ErrorAction Stop
        Write-Host "Redis 服务已停止。" -ForegroundColor Green
    } catch {
        Write-Host "停止 Redis 服务时出错: $_" -ForegroundColor Red
    }
}

# 启动FastAPI后端
function Start-FastAPIBackend {
    if (Test-PortListening 5001) {
        Write-Host "FastAPI 后端已经在运行 (端口 5001)。" -ForegroundColor Yellow
        return
    }

    Write-Host "正在启动 FastAPI 后端..." -ForegroundColor Cyan
    $cmd = 'cd /d "' + $ProjectRoot + '" && set PYTHONIOENCODING=utf-8 && py -3 -m uvicorn fastapi_backend.main:app --host 0.0.0.0 --port 5001 --reload'
    Start-Process -FilePath "cmd.exe" -ArgumentList "/k", $cmd -WorkingDirectory $ProjectRoot
    Write-Host "已打开 FastAPI 后端窗口。" -ForegroundColor Green
}

# 停止FastAPI后端
function Stop-FastAPIBackend {
    if (-not (Test-PortListening 5001)) {
        Write-Host "FastAPI 后端当前没有运行。" -ForegroundColor Yellow
        return
    }

    Write-Host "正在停止 FastAPI 后端..." -ForegroundColor Cyan
    $lines = netstat -ano | Select-String ":5001" | Select-String "LISTENING"
    $pids = @()

    foreach ($line in $lines) {
        $parts = ($line.ToString() -split '\s+') | Where-Object { $_ }
        if ($parts.Count -ge 5) {
            $pids += $parts[-1]
        }
    }

    $pids = $pids | Select-Object -Unique
    foreach ($pid in $pids) {
        Stop-Process -Id $pid -Force -ErrorAction SilentlyContinue
    }

    Write-Host "FastAPI 后端已停止。" -ForegroundColor Green
}

# 启动前端服务
function Start-Frontend {
    if (Test-PortListening 5173) {
        Write-Host "前端已经在运行 (端口 5173)。" -ForegroundColor Yellow
        return
    }

    Write-Host "正在启动前端服务..." -ForegroundColor Cyan
    $cmd = 'cd /d "' + $ProjectRoot + '\frontend" && npm run dev'
    Start-Process -FilePath "cmd.exe" -ArgumentList "/k", $cmd -WorkingDirectory "$ProjectRoot\frontend"
    Write-Host "已打开前端服务窗口。" -ForegroundColor Green
}

# 停止前端服务
function Stop-Frontend {
    if (-not (Test-PortListening 5173)) {
        Write-Host "前端当前没有运行。" -ForegroundColor Yellow
        return
    }

    Write-Host "正在停止前端服务..." -ForegroundColor Cyan
    $lines = netstat -ano | Select-String ":5173" | Select-String "LISTENING"
    $pids = @()

    foreach ($line in $lines) {
        $parts = ($line.ToString() -split '\s+') | Where-Object { $_ }
        if ($parts.Count -ge 5) {
            $pids += $parts[-1]
        }
    }

    $pids = $pids | Select-Object -Unique
    foreach ($pid in $pids) {
        Stop-Process -Id $pid -Force -ErrorAction SilentlyContinue
    }

    Write-Host "前端已停止。" -ForegroundColor Green
}

# 启动所有服务
function Start-AllServices {
    Write-Host "正在启动所有服务..." -ForegroundColor Cyan
    Start-RedisService
    Start-Sleep -Seconds 2
    Start-FastAPIBackend
    Start-Sleep -Seconds 2
    Start-Frontend
    Write-Host "所有服务启动完成。" -ForegroundColor Green
}

# 停止所有服务
function Stop-AllServices {
    Write-Host "正在停止所有服务..." -ForegroundColor Cyan
    Stop-Frontend
    Start-Sleep -Seconds 1
    Stop-FastAPIBackend
    Start-Sleep -Seconds 1
    Stop-RedisService
    Write-Host "所有服务已停止。" -ForegroundColor Green
}

# 打开URL
function Open-Url {
    param([string]$Url)
    Start-Process $Url
}

# 主菜单循环
while ($true) {
    Clear-Host
    Write-Host "========================================" -ForegroundColor Cyan
    Write-Host "      TestMaster 服务控制台 (中文版)" -ForegroundColor Cyan
    Write-Host "========================================" -ForegroundColor Cyan
    Write-Host "项目目录: $ProjectRoot"
    Write-Host "Redis 地址: $RedisUrl"
    Show-Status

    Write-Host "=== 菜单选项 ===" -ForegroundColor Cyan
    Write-Host "1. 启动全部服务"
    Write-Host "2. 停止全部服务"
    Write-Host "3. 刷新状态"
    Write-Host ""
    Write-Host "4. 启动 Redis"
    Write-Host "5. 停止 Redis"
    Write-Host "6. 启动 FastAPI 后端"
    Write-Host "7. 停止 FastAPI 后端"
    Write-Host "8. 启动前端"
    Write-Host "9. 停止前端"
    Write-Host ""
    Write-Host "10. 打开前端页面"
    Write-Host "11. 打开 FastAPI 文档"
    Write-Host ""
    Write-Host "0. 退出"
    Write-Host ""

    $choice = Read-Host "请输入编号"

    switch ($choice) {
        "1" { Start-AllServices }
        "2" { Stop-AllServices }
        "3" { }
        "4" { Start-RedisService }
        "5" { Stop-RedisService }
        "6" { Start-FastAPIBackend }
        "7" { Stop-FastAPIBackend }
        "8" { Start-Frontend }
        "9" { Stop-Frontend }
        "10" { Open-Url "http://127.0.0.1:5173" }
        "11" { Open-Url "http://127.0.0.1:5001/api/docs" }
        "0" {
            Write-Host "退出服务控制台。" -ForegroundColor Cyan
            break
        }
        default {
            Write-Host "输入无效，请重新选择。" -ForegroundColor Red
        }
    }

    if ($choice -ne "0") {
        Write-Host ""
        Write-Host "按任意键继续..." -ForegroundColor Gray
        $null = $Host.UI.RawUI.ReadKey("NoEcho,IncludeKeyDown")
    }
}

Write-Host "服务控制台已关闭。" -ForegroundColor Cyan